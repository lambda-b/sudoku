{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "allowJs": false,
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "paths": {
      "@/*": ["./src/*"],
      "@sudoku/core": ["./packages/core/src/index.ts"],
      "@sudoku/core/*": ["./packages/core/src/*"],
      "@sudoku/solver": ["./packages/solver/src/index.ts"],
      "@sudoku/solver/*": ["./packages/solver/src/*"],
      "@sudoku/ui/*": ["./packages/ui/src/*"]
    }
  },
  "include": [
    "src",
    "packages/core/src",
    "packages/solver/src",
    "packages/ui/src",
    "vite.config.ts"
  ]
}
